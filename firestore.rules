rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidGame(data) {
      return data.status in ['waiting', 'playing', 'finished'] &&
             data.hostId is string;
    }

    function isValidPlayer(data) {
      return data.nickname is string && data.nickname.size() > 0 && data.nickname.size() < 20 &&
             data.score is number &&
             data.streak is number;
    }

    match /games/{gameId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidGame(request.resource.data) && request.resource.data.hostId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.hostId == request.auth.uid || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'startTime']));
      
      match /players/{playerId} {
        allow read: if isAuthenticated();
        allow create: if isOwner(playerId) && isValidPlayer(request.resource.data);
        allow update: if isOwner(playerId) && isValidPlayer(request.resource.data);
      }
    }
    
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
